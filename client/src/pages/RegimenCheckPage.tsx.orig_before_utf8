          if (v === null) return 0;
          if (v > 120) return 3; if (v > 40) return 2; return 1;
        }
        case 'ALT': {
          const v = latest.alt != null ? Number(latest.alt) : null;
          if (v === null) return 0;
          if (v > 120) return 3; if (v > 40) return 2; return 1;
        }
        case 'Cre': {
